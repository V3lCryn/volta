{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Volta",
  "scopeName": "source.volta",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#builtin" },
    { "include": "#operator" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.block.volta",
          "begin": "--\\[\\[",
          "end": "\\]\\]"
        },
        {
          "name": "comment.line.double-dash.volta",
          "match": "--.*$"
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.volta",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.volta",
          "match": "\\\\[ntr\"\\\\0{]"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.volta",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.volta",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.volta",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.volta",
          "match": "\\b(if|elseif|else|while|for|in|do|end|return|break|continue|match)\\b"
        },
        {
          "name": "keyword.declaration.volta",
          "match": "\\b(fn|let|const|struct|packed|enum|extern|device|import|pub)\\b"
        },
        {
          "name": "keyword.operator.logical.volta",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.volta",
          "match": "\\b(nil|true|false)\\b"
        },
        {
          "name": "keyword.other.volta",
          "match": "\\b(as)\\b"
        }
      ]
    },
    "type": {
      "name": "support.type.volta",
      "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|str|bool|ptr|void|Result)\\b"
    },
    "builtin": {
      "name": "support.function.builtin.volta",
      "match": "\\b(print|println|len|push|pop|assert|exit|to_str|to_int|to_float|Ok|Err)\\b"
    },
    "operator": {
      "name": "keyword.operator.volta",
      "match": "(\\.\\.=?|=>|->|[+\\-*/%]=?|==|!=|<=?|>=?|&&?|\\|\\|?|\\^|~|<<|>>|\\?|@)"
    },
    "identifier": {
      "patterns": [
        {
          "name": "entity.name.function.volta",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "variable.other.volta",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
