{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["do", "end"],
    ["fn", "end"],
    ["if", "end"],
    ["while", "end"],
    ["for", "end"],
    ["match", "end"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\b(fn|if|elseif|else|while|for|do|match)\\b.*$",
    "decreaseIndentPattern": "^\\s*\\bend\\b"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
