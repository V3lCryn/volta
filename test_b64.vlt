import "lib/crypto"

let s1 = "attack at dawn"
let s2 = "SGVsbG8gV29ybGQ="
let s3 = "hello"

print("len of s1: " .. int_to_str(str_len(s1)))
print("len of s2: " .. int_to_str(str_len(s2)))
print("len % 4 s1: " .. int_to_str(str_len(s1) % 4))
print("len % 4 s2: " .. int_to_str(str_len(s2) % 4))
print("s1 b64: " .. bool_to_str(looks_base64(s1)))
print("s2 b64: " .. bool_to_str(looks_base64(s2)))
print("char 4 of s1: " .. int_to_str(char_at(s1, 4)))
print("is_b64_char(32): " .. bool_to_str(is_b64_char(32)))
